{
  "expo": {
    "name": "TM Health",
    "slug": "tm-health-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1C6DD0"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.trendmicro.healthtracker"
    },
    "android": {
      "package": "com.trendmicro.healthtracker",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1C6DD0"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
